        "y": 0
      },
      "id": 2,
      "title": "CPU Usage Distribution (Bell-Curve Analysis)",
      "type": "histogram",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
