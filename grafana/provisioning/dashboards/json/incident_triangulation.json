      "id": 3,
      "title": "Container Log Stream (incident Triangulation)",
      "type": "logs",
      "datasource": {
        "type": "elasticsearch",
        "uid": "elasticsearch-logs"
      },
      "targets": [
        {
          "datasource": {
            "type": "elasticsearch",
            "uid": "elasticsearch-logs"
          },
          "query": "container_name:\"$container\" OR log:\"$container\"",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "showCommonLabels": true
      }
    }
