            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=~\"$container\"}[1m])) by (container) * 100",
          "legendFormat": "{{name}} CPU Distribution",
          "range": true
        }
      ],
      "options": {
        "combine": false
      }
    },
    {
      "collapsed": false,
      "gridPos": {
