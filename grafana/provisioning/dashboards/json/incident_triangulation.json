      "id": 1,
      "title": "Container CPU Usage (Current vs. Average Baseline)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=~\"$container\"}[1m])) by (container) * 100",
          "legendFormat": "Current {{name}}",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "avg_over_time(sum(rate(container_cpu_usage_seconds_total{container=~\"$container\"}[1m])) by (container)[1h]) * 100",
          "legendFormat": "Baseline 1h {{name}}",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "avg_over_time(sum(rate(container_cpu_usage_seconds_total{container=~\"$container\"}[1m])) by (container)[1h]) * 100 + 2 * stddev_over_time(sum(rate(container_cpu_usage_seconds_total{container=~\"$container\"}[1m])) by (container)[1h]) * 100",
          "legendFormat": "+2 SD {{name}}",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
