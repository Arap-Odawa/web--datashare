      "id": 1,
      "title": "Request Rate (Current vs. Average Baseline & SD Envelope)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)",
          "legendFormat": "Current {{category}} - {{function_name}} ({{status}})",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "avg_over_time(sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)[1h])",
          "legendFormat": "Baseline 1h {{category}} - {{function_name}} ({{status}})",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "avg_over_time(sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)[1h]) + 2 * stddev_over_time(sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)[1h])",
          "legendFormat": "+2 SD {{category}} - {{function_name}} ({{status}})",
          "range": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "clamp_min(avg_over_time(sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)[1h]) - 2 * stddev_over_time(sum(rate(dash_app_function_requests_total{category=~\"$category\", function_name=~\"$function_name\"}[1m])) by (category, function_name, status)[1h]), 0)",
          "legendFormat": "-2 SD {{category}} - {{function_name}} ({{status}})",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
